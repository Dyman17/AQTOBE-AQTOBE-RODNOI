OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# timetable source:
# - edupage (default): live data from EduPage RPC
# - mock: local static data from mock_data.py
TIMETABLE_SOURCE=edupage
EDUPAGE_SCHOOL=nisaktau
# EDUPAGE_YEAR=2025
# EDUPAGE_TT_NUM=119
EDUPAGE_TIMEOUT_SECONDS=25
EDUPAGE_CACHE_TTL_SECONDS=300
EDUPAGE_TIMEZONE=Asia/Almaty
