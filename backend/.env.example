AI_PROVIDER=openrouter
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=your_openrouter_api_key
AI_MODEL_PRIMARY=stepfun/step-3.5-flash:free
AI_MODEL_FALLBACKS=nvidia/nemotron-3-super-120b-a12b:free
# Optional OpenRouter attribution headers:
# AI_APP_URL=https://your-app.example
# AI_APP_NAME=Aqbobek Portal

# timetable source:
# - edupage (default): live data from EduPage RPC
# - mock: local static data from mock_data.py
TIMETABLE_SOURCE=edupage
EDUPAGE_SCHOOL=nisaktau
# EDUPAGE_YEAR=2025
# EDUPAGE_TT_NUM=119
EDUPAGE_TIMEOUT_SECONDS=25
EDUPAGE_CACHE_TTL_SECONDS=300
EDUPAGE_TIMEZONE=Asia/Almaty

# Strict CORS allowlist for local frontend dev servers:
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:5176
